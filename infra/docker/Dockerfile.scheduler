# syntax=docker/dockerfile:1

# ── install deps ────────────────────────────────────
FROM node:22-slim AS deps
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install

# ── build app ───────────────────────────────────────────────────────────
FROM deps AS builder
ENV NX_DAEMON=false

COPY . .

RUN npx nx build scheduler
RUN npx nx run scheduler:prune

# ── run prod image ─────────────────────────────────────────────────
FROM node:22-slim AS runner
WORKDIR /app

COPY --from=builder --chown=node:node /app/dist/apps/scheduler ./

RUN npm ci --omit=dev

USER node

CMD ["node", "main.js"]
